# Base da plataforma (sem / no final)
QT_API_BASE_URL=https://api.querotruck.com.br

# Base do Web.Api (default: ${QT_API_BASE_URL}/web/v1)
QT_WEB_API_BASE_URL=https://api.querotruck.com.br/web/v1

# Well-known OIDC (sem versionamento)
QT_OIDC_WELL_KNOWN_URL=https://api.querotruck.com.br/auth/.well-known/openid-configuration

# Dados do seu client OIDC
QT_CLIENT_ID=SEU_CLIENT_ID
QT_REDIRECT_URI=http://localhost:8787/callback
QT_SCOPE=openid profile email

# Origin permitida (quando sua integração é browser-based)
# Para backend-to-backend, pode deixar vazio e usar scope web.client.integration.
QT_ORIGIN=

# Token opcional (se já tiver). Se vazio, o CLI tenta ler .runtime/token.json
QT_ACCESS_TOKEN=

# ------------------------------------------------------------
# Opcional: login dev automatizado (localhost)
# auth:dev-login usa connect/token + oidc/bootstrap
# ------------------------------------------------------------
QT_DEV_EMAIL=dev.admin@querotruck.com.br
QT_DEV_PASSWORD=123456
QT_DEV_CLIENT_ID=QueroTruck.Web
QT_DEV_SCOPE=authenticate
QT_DEV_ORIGIN=http://localhost:3000
QT_DEV_CONNECT_TOKEN_URL=https://api.querotruck.com.br/auth/v1/connect/token
QT_DEV_OIDC_BOOTSTRAP_URL=https://api.querotruck.com.br/auth/v1/oidc/bootstrap
